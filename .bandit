# Bandit configuration for mypylogger security scanning
exclude_dirs:
  - tests
  - build
  - dist
  - .git
  - .venv
  - venv
  - __pycache__
  - .pytest_cache
  - htmlcov

# Test IDs to skip (with justification)
skips:
  # B101: Test for use of assert - we use asserts in tests which is acceptable
  # B404: subprocess import - legitimate use for git commands in scripts
  # B603: subprocess without shell - safe usage with hardcoded git commands
  # B607: partial executable path - git is in PATH and safe to use
  - B404
  - B603
  - B607

# Confidence levels: LOW, MEDIUM, HIGH
confidence: MEDIUM

# Severity levels: LOW, MEDIUM, HIGH
severity: MEDIUM

# Output format options: csv, json, txt, xml, yaml
format: txt

# Include full path in output
absolute_paths: true

# Aggregate output by vulnerability type
aggregate: vuln
